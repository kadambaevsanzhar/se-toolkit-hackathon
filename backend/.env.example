# Database Configuration
DATABASE_URL=postgresql://grader:grader@db:5432/grader_dev

# Real Qwen AI v1 API Configuration
# For local/VM deployment of qwen-code-api service
AI_BASE_URL=http://localhost:42006/v1
AI_API_KEY=my-secret-qwen-key
AI_MODEL=qwen3-coder-plus
AI_MAX_SCORE=10
AI_TIMEOUT=30

# Or for remote server deployment:
# AI_BASE_URL=http://<IP_VM>:42006/v1
# If backend on same VM:
# AI_BASE_URL=http://localhost:42006/v1

# Telegram Bot Configuration
TELEGRAM_TOKEN=your-telegram-bot-token-here
BACKEND_URL=http://backend:8000

# Application Configuration
MAX_UPLOAD_SIZE_MB=10
LOG_LEVEL=INFO
